    <Style x:Key="SettingsCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource PanelBorderThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource SettingsCardCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource SettingsCardPadding}" />
        <Setter Property="MinHeight" Value="{StaticResource SettingsCardMinHeight}" />
    </Style>
    <Style x:Key="SettingsPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LauncherBoldFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource SettingsTitleSize}" />
        <Setter Property="CharacterSpacing" Value="-12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LauncherMediumFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource SettingsLabelSize}" />
        <Setter Property="CharacterSpacing" Value="-4" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="SettingsDescriptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LauncherFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource SettingsDescriptionSize}" />
        <Setter Property="CharacterSpacing" Value="-2" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,3,0,0" />
    </Style>
    <Style x:Key="SettingsGroupHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LauncherMediumFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="8" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="Margin" Value="{StaticResource SettingsGroupHeaderMargin}" />
    </Style>
    <Style x:Key="SettingsErrorTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LauncherFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource SettingsDescriptionSize}" />
        <Setter Property="Foreground" Value="{ThemeResource LauncherErrorBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="{StaticResource SettingsErrorMargin}" />
    </Style>
    <!-- 自前タイトルバーの閉じるボタン。Windows純正のキャプションボタンは使わず、設定画面の面に馴染む形にする -->
    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource QueryBoxBorderThickness}" />
        <Setter Property="Padding" Value="{StaticResource QueryBoxPadding}" />
        <Setter Property="Width" Value="{StaticResource TitleBarButtonSize}" />
        <Setter Property="Height" Value="{StaticResource TitleBarButtonSize}" />
        <Setter Property="CornerRadius" Value="{StaticResource TitleBarButtonCornerRadius}" />
        <Setter Property="Margin" Value="{StaticResource TitleBarButtonMargin}" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid
                        x:Name="TitleBarButtonRoot"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="TitleBarButtonRoot.Background" Value="{ThemeResource TitleBarButtonHoverBrush}" />
                                        <Setter Target="TitleBarButtonContent.Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="TitleBarButtonRoot.Background" Value="{ThemeResource TitleBarButtonPressedBrush}" />
                                        <Setter Target="TitleBarButtonContent.Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="TitleBarButtonContent.Foreground" Value="{ThemeResource TextFillColorDisabledBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter
                            x:Name="TitleBarButtonContent"
                            Content="{TemplateBinding Content}"
                            Foreground="{TemplateBinding Foreground}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="TitleBarCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LauncherMediumFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource TitleBarCaptionSize}" />
        <Setter Property="CharacterSpacing" Value="-4" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="Margin" Value="{StaticResource TitleBarCaptionMargin}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style x:Key="SettingsRowIconStyle" TargetType="FontIcon">
        <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
        <Setter Property="FontSize" Value="{StaticResource SettingsRowIconSize}" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="Margin" Value="{StaticResource SettingsCardIconMargin}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
</ResourceDictionary>
