<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="LauncherFallbackBrush" Color="#CCF7F7F7" />
            <!--
                設定/Welcome画面のThin Acrylicへ薄く重ねて素材を一段濃く（不透明に）見せるスクリム。
                素材のTintOpacity/LuminosityOpacityには触れないため、テーマ変更時の自動再導出は生きたまま。
                Lightは自面の白を薄く足し、Dark/Defaultは自面の黒を薄く足して透け具合だけを抑える。
            -->
            <SolidColorBrush x:Key="AppSurfaceScrimBrush" Color="#29FFFFFF" />
            <!-- 設定ウィンドウのナビ/コンテンツを一段ずつ濃くする階層用スクリム。素材のTint/Luminosityには触れない。 -->
            <SolidColorBrush x:Key="SettingsNavScrimBrush" Color="#14000000" />
            <SolidColorBrush x:Key="SettingsContentLayerBrush" Color="#40FFFFFF" />
            <SolidColorBrush x:Key="LauncherErrorBrush" Color="#C42B1C" />
            <SolidColorBrush x:Key="LauncherWarningBrush" Color="#9A6700" />
            <SolidColorBrush x:Key="StatusRowBrush" Color="#59FFFFFF" />
            <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#14000000" />
            <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#1F000000" />
            <SolidColorBrush x:Key="CategoryChipBrush" Color="#18007AFF" />
            <SolidColorBrush x:Key="QuickKeyBrush" Color="#14000000" />
            <SolidColorBrush x:Key="LauncherTintBrush" Color="#40FFFFFF" />
            <SolidColorBrush x:Key="LauncherBorderBrush" Color="#1A000000" />
            <SolidColorBrush x:Key="LauncherTextBrush" Color="#1D1D1F" />
            <SolidColorBrush x:Key="LauncherInputTextBrush" Color="#E6000000" />
            <SolidColorBrush x:Key="LauncherResultTitleBrush" Color="#D9000000" />
            <SolidColorBrush x:Key="LauncherSecondaryTextBrush" Color="#8F000000" />
            <SolidColorBrush x:Key="LauncherPlaceholderBrush" Color="#73000000" />
            <SolidColorBrush x:Key="LauncherWeakTextBrush" Color="#59000000" />
            <SolidColorBrush x:Key="LauncherDisabledTextBrush" Color="#3D000000" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#16000000" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#1C000000" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#22000000" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="LauncherFallbackBrush" Color="#CC202020" />
            <SolidColorBrush x:Key="AppSurfaceScrimBrush" Color="#3D000000" />
            <SolidColorBrush x:Key="SettingsNavScrimBrush" Color="#1F000000" />
            <SolidColorBrush x:Key="SettingsContentLayerBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="LauncherErrorBrush" Color="#FF99A4" />
            <SolidColorBrush x:Key="LauncherWarningBrush" Color="#FCE100" />
            <SolidColorBrush x:Key="StatusRowBrush" Color="#40000000" />
            <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#1AFFFFFF" />
            <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="CategoryChipBrush" Color="#28007AFF" />
            <SolidColorBrush x:Key="QuickKeyBrush" Color="#20FFFFFF" />
            <SolidColorBrush x:Key="LauncherTintBrush" Color="#33262626" />
            <SolidColorBrush x:Key="LauncherBorderBrush" Color="#2AFFFFFF" />
            <SolidColorBrush x:Key="LauncherTextBrush" Color="#F2FFFFFF" />
            <SolidColorBrush x:Key="LauncherInputTextBrush" Color="#F2FFFFFF" />
            <SolidColorBrush x:Key="LauncherResultTitleBrush" Color="#E8FFFFFF" />
            <SolidColorBrush x:Key="LauncherSecondaryTextBrush" Color="#A3FFFFFF" />
            <SolidColorBrush x:Key="LauncherPlaceholderBrush" Color="#8AFFFFFF" />
            <SolidColorBrush x:Key="LauncherWeakTextBrush" Color="#70FFFFFF" />
            <SolidColorBrush x:Key="LauncherDisabledTextBrush" Color="#4DFFFFFF" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#20FFFFFF" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#28FFFFFF" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#30FFFFFF" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="LauncherErrorBrush" Color="#FF99A4" />
            <SolidColorBrush x:Key="LauncherWarningBrush" Color="#FCE100" />
            <SolidColorBrush x:Key="StatusRowBrush" Color="#40000000" />
            <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#1AFFFFFF" />
            <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="CategoryChipBrush" Color="#28007AFF" />
            <SolidColorBrush x:Key="QuickKeyBrush" Color="#20FFFFFF" />
            <SolidColorBrush x:Key="LauncherFallbackBrush" Color="#CC202020" />
            <SolidColorBrush x:Key="AppSurfaceScrimBrush" Color="#3D000000" />
            <SolidColorBrush x:Key="SettingsNavScrimBrush" Color="#1F000000" />
            <SolidColorBrush x:Key="SettingsContentLayerBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="LauncherTintBrush" Color="#33262626" />
            <SolidColorBrush x:Key="LauncherBorderBrush" Color="#2AFFFFFF" />
            <SolidColorBrush x:Key="LauncherTextBrush" Color="#F2FFFFFF" />
            <SolidColorBrush x:Key="LauncherInputTextBrush" Color="#F2FFFFFF" />
            <SolidColorBrush x:Key="LauncherResultTitleBrush" Color="#E8FFFFFF" />
            <SolidColorBrush x:Key="LauncherSecondaryTextBrush" Color="#A3FFFFFF" />
            <SolidColorBrush x:Key="LauncherPlaceholderBrush" Color="#8AFFFFFF" />
            <SolidColorBrush x:Key="LauncherWeakTextBrush" Color="#70FFFFFF" />
            <SolidColorBrush x:Key="LauncherDisabledTextBrush" Color="#4DFFFFFF" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#20FFFFFF" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#28FFFFFF" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#30FFFFFF" />
        </ResourceDictionary>
        <!--
            ハイコントラストでは独自配色を持たず、必ずシステム色へ委ねる。
            半透明も使わない（背景が透けると保証されたコントラストが崩れるため）。
            ListViewItemBackgroundSelected* はWinUI標準のハイコントラスト値をそのまま使うので定義しない。
        -->
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="LauncherFallbackBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <!-- ハイコントラストではシステム配色を乱さないよう、スクリムは無効（透明）にする。 -->
            <SolidColorBrush x:Key="AppSurfaceScrimBrush" Color="Transparent" />
            <SolidColorBrush x:Key="SettingsNavScrimBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="SettingsContentLayerBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="LauncherErrorBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="LauncherWarningBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="StatusRowBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="CategoryChipBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="QuickKeyBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="LauncherTintBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="LauncherBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="LauncherTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="LauncherInputTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="LauncherResultTitleBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="LauncherSecondaryTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="LauncherPlaceholderBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
            <SolidColorBrush x:Key="LauncherWeakTextBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
            <SolidColorBrush x:Key="LauncherDisabledTextBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
