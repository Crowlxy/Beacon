<Window
    x:Class="Beacon.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        x:Name="Panel"
        Background="{ThemeResource LauncherTintBrush}"
        BorderBrush="{ThemeResource LauncherBorderBrush}"
        BorderThickness="{StaticResource PanelBorderThickness}"
        CornerRadius="{StaticResource SearchBarCornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{StaticResource SearchBarGridHeight}" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Padding="{StaticResource SearchPadding}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="{StaticResource SearchIconSize}" Foreground="{ThemeResource LauncherTextBrush}" Glyph="&#xE721;" Margin="{StaticResource SearchIconMargin}" VerticalAlignment="Center" />
                <TextBox
                    x:Name="QueryBox"
                    Grid.Column="1"
                    Background="{StaticResource TransparentBrush}"
                    BorderBrush="{StaticResource TransparentBrush}"
                    BorderThickness="{StaticResource QueryBoxBorderThickness}"
                    Padding="{StaticResource SearchTextPadding}"
                    FontSize="{StaticResource SearchFontSize}"
                    FontFamily="{StaticResource LauncherMediumFontFamily}"
                    Foreground="{ThemeResource LauncherInputTextBrush}"
                    VerticalAlignment="Center"
                    TextChanged="OnQueryTextChanged"
                    TextCompositionStarted="OnCompositionStarted"
                    TextCompositionEnded="OnCompositionEnded"
                    KeyDown="OnQueryKeyDown" />
                <TextBlock
                    x:Name="QueryPlaceholder"
                    Grid.Column="1"
                    FontSize="{StaticResource SearchFontSize}"
                    FontFamily="{StaticResource LauncherMediumFontFamily}"
                    Foreground="{ThemeResource LauncherPlaceholderBrush}"
                    Text="Anything..."
                    Margin="{StaticResource SearchPlaceholderPadding}"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False" />
                <TextBlock
                    x:Name="GhostCompletion"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    FontFamily="{StaticResource QuickKeyFontFamily}"
                    FontSize="{StaticResource CategoryChipFontSize}"
                    Foreground="{ThemeResource LauncherWeakTextBrush}"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False" />
            </Grid>
            <Border
                x:Name="ScopeChip"
                Grid.Row="1"
                Height="{StaticResource CategoryChipHeight}"
                HorizontalAlignment="Left"
                Margin="{StaticResource CategoryChipRowMargin}"
                Padding="{StaticResource CategoryChipPadding}"
                CornerRadius="{StaticResource CategoryChipCornerRadius}"
                Background="{StaticResource CategoryChipBrush}"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ScopeChipText" FontFamily="{StaticResource LauncherFontFamily}" FontSize="{StaticResource CategoryChipFontSize}" VerticalAlignment="Center" />
                    <Button Content="×" Click="OnScopeChipClose" Background="{StaticResource TransparentBrush}" BorderThickness="{StaticResource QueryBoxBorderThickness}" Padding="{StaticResource QueryBoxPadding}" />
                </StackPanel>
            </Border>
            <ListView
                x:Name="ResultsList"
                Grid.Row="2"
                Margin="{StaticResource ResultsMargin}"
                IsItemClickEnabled="True"
                ItemClick="OnResultClicked"
                SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="MinHeight" Value="{StaticResource ResultRowHeight}" />
                        <Setter Property="Margin" Value="{StaticResource ResultItemMargin}" />
                        <Setter Property="Padding" Value="{StaticResource QueryBoxPadding}" />
                        <Setter Property="BorderThickness" Value="{StaticResource QueryBoxBorderThickness}" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="{StaticResource ResultRowHeight}" Padding="{StaticResource ResultPadding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="{StaticResource ResultIconSize}" Height="{StaticResource ResultIconSize}" Margin="{StaticResource ResultIconMargin}" CornerRadius="{StaticResource ResultIconCornerRadius}">
                                <Grid>
                                    <FontIcon FontFamily="Segoe Fluent Icons" FontSize="{StaticResource ResultIconSize}" Glyph="{Binding Glyph}" Visibility="{Binding GlyphVisibility}" />
                                    <Image Source="{Binding Image}" Stretch="Uniform" Visibility="{Binding ImageVisibility}" />
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource LauncherFontFamily}" FontSize="{StaticResource ResultTitleSize}" Foreground="{ThemeResource LauncherResultTitleBrush}" Text="{Binding Result.Title}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontFamily="{StaticResource LauncherFontFamily}" FontSize="{StaticResource ResultSubtitleSize}" Margin="{StaticResource ResultSubtitleMargin}" Foreground="{ThemeResource LauncherSecondaryTextBrush}" Text="{Binding Result.Subtitle}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Border Grid.Column="2" Background="{StaticResource QuickKeyBrush}" CornerRadius="{StaticResource CategoryChipCornerRadius}" Padding="{StaticResource QuickKeyPadding}" Margin="{StaticResource QuickKeyMargin}" VerticalAlignment="Center" Visibility="{Binding QuickKeyVisibility}">
                                <TextBlock FontFamily="{StaticResource QuickKeyFontFamily}" FontSize="{StaticResource CategoryChipFontSize}" Foreground="{ThemeResource LauncherWeakTextBrush}" Text="{Binding QuickKey}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</Window>
